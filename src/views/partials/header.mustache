<header class="header">
    <a href="/" class="logo">
        <img src="/images/logo.png" alt="Holy'n" class="logo-img">
        <span class="logo-text">Holy'n</span>
    </a>
    {{^hideSearch}}
    <div class="search-wrapper">
        <input type="text" class="search-input" placeholder="Rechercher un pari...">
    </div>
    <script>
    (function () {
        var input = document.currentScript.previousElementSibling.querySelector('.search-input');
        if (!input) return;
        var params = new URLSearchParams(location.search);
        var q = params.get('search');
        if (q) input.value = q;
        input.addEventListener('keydown', function (e) {
            if (e.key !== 'Enter') return;
            var val = input.value.trim();
            var url = new URL('/', location.origin);
            if (val) url.searchParams.set('search', val);
            var tag = params.get('tag');
            if (tag) url.searchParams.set('tag', tag);
            location.href = url.toString();
        });
    })();
    </script>
    {{/hideSearch}}
    <div class="header-actions">
        {{#user}}
        <div class="user-info">
            <div class="user-stat">
                <span class="stat-label">Volume</span>
                {{! -manque une route get /stats/user/:id }}
                <span class="stat-value">—</span>
            </div>
            <div class="user-stat">
                <span class="stat-label">Solde</span>
                <span class="stat-value">{{solde}}€</span>
            </div>
            <div class="user-menu" onclick="toggleMenu()">
                <div class="avatar-circle">{{pseudo_initial}}</div>
                <span class="username">{{pseudo}}</span>
                <div class="dropdown" id="user-dropdown">
                    <a href="/profile" class="dropdown-item">Mon profil</a>
                    <a href="/wallet" class="dropdown-item">Mon portefeuille</a>
                    {{#admin}}
                    <a href="/admin" class="dropdown-item">Administration</a>
                    {{/admin}}
                    <button onclick="logout()" class="dropdown-item dropdown-logout">Se déconnecter</button>
                </div>
            </div>
        </div>
        {{/user}}
        {{^user}}
        <a href="/login" class="btn btn-orange">Se connecter</a>
        <a href="/register" class="btn btn-navy">S'inscrire</a>
        {{/user}}
    </div>
</header>
