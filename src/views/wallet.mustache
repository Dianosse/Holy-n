<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Holy'n - Mon portefeuille</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    {{> header}}

    <main class="main-content">
        <div class="page-header">
            <h1 class="page-title">Mon portefeuille</h1>
        </div>

        <div class="wallet-stats">
            <div class="wallet-stat-card">
                <span class="wallet-stat-label">Solde disponible</span>
                <span class="wallet-stat-value orange" id="solde-display">{{solde}}€</span>
            </div>
            <div class="wallet-stat-card">
                <span class="wallet-stat-label">Mises en cours</span>
                <span class="wallet-stat-value">{{totalMise}}€</span>
            </div>
        </div>

        <div class="wallet-forms">
            <div class="wallet-form-card">
                <h2 class="wallet-form-title">Déposer des fonds</h2>
                <div id="deposit-error" class="error-message"></div>
                <div id="deposit-success" class="success-message"></div>
                <form onsubmit="deposit(event)">
                    <div class="form-group">
                        <label class="form-label">Montant (€)</label>
                        <input type="number" name="argent" class="form-input" placeholder="0.00" min="0.01" step="0.01" required>
                    </div>
                    <button type="submit" class="btn btn-orange btn-full">Déposer</button>
                </form>
            </div>

            <div class="wallet-form-card">
                <h2 class="wallet-form-title">Retirer des fonds</h2>
                <div id="withdraw-error" class="error-message"></div>
                <div id="withdraw-success" class="success-message"></div>
                <form onsubmit="withdraw(event)">
                    <div class="form-group">
                        <label class="form-label">Montant (€)</label>
                        <input type="number" name="argent" class="form-input" placeholder="0.00" min="0.01" step="0.01" required>
                    </div>
                    <button type="submit" class="btn btn-navy btn-full">Retirer</button>
                </form>
            </div>
        </div>
    </main>

    <script src="/js/auth.js"></script>
    <script src="/js/wallet.js"></script>

</body>
</html>
