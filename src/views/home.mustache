<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Holy'n - Paris en ligne</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    {{> header}}

    <nav class="nav-tags">
        <a href="/" class="tag-item{{#noTagSelected}} active{{/noTagSelected}}">Tous</a>
        {{#tags}}
        <a href="/?tag={{libelle}}" class="tag-item{{#actif}} active{{/actif}}">{{libelle}}</a>
        {{/tags}}
    </nav>

    <main class="main-content">
        <div class="polls-header">
            {{#searchQuery}}
            <div class="search-result-info">
                Résultats pour <strong>«&nbsp;{{searchQuery}}&nbsp;»</strong>
                <a href="/" class="search-clear">✕ Effacer</a>
            </div>
            {{/searchQuery}}
            {{#user}}
            <a href="/polls/submit" class="btn btn-orange">+ Créer un pari</a>
            {{/user}}
        </div>

        <div class="bets-grid">
            {{#paris}}
            <a href="/polls/{{poll_id}}" class="bet-card-link">
                <div class="bet-card">
                    <div class="tag-chips">
                        {{#tags_list}}<span class="tag-chip">{{libelle}}</span>{{/tags_list}}
                    </div>
                    <div class="bet-card-header">
                        <p class="bet-question">{{intitule}}</p>
                    </div>
                    <div class="bet-choices">
                        {{#choix_a}}<span class="poll-card-choice orange">{{libelle}}</span>{{/choix_a}}
                        {{#choix_b}}<span class="poll-card-choice navy">{{libelle}}</span>{{/choix_b}}
                        {{#voir_plus}}<span class="poll-card-choice navy full">Voir les {{nb}} choix</span>{{/voir_plus}}
                    </div>
                    {{#datecloture_str}}
                    <p class="bet-volume">Clôture le {{datecloture_str}}</p>
                    {{/datecloture_str}}
                </div>
            </a>
            {{/paris}}
            {{^paris}}
            <div class="empty-state" style="grid-column: 1/-1;">
                {{#searchQuery}}<p>Aucun pari ne correspond à «&nbsp;{{searchQuery}}&nbsp;».</p>{{/searchQuery}}
                {{^searchQuery}}<p>Aucun pari actif pour le moment.</p>{{/searchQuery}}
            </div>
            {{/paris}}
        </div>
    </main>

    <script src="/js/auth.js"></script>

</body>
</html>
