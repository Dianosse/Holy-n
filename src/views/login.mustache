<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Holy'n - Connexion</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

    {{> header}}

    <div class="auth-page">
        <div class="auth-card">

            <a href="/" class="auth-logo">
                <img src="/images/logo.png" alt="Holy'n">
                <span class="auth-logo-text">Holy'n</span>
            </a>

            <h1 class="auth-title">Connexion</h1>
            <p class="auth-subtitle">Bon retour parmi nous !</p>

            <div id="success-msg" class="success-message"></div>
            <div id="error-msg" class="error-message"></div>

            <form onsubmit="submitLogin(event)">
                <div class="form-group">
                    <label class="form-label" for="mail">Adresse e-mail</label>
                    <input type="email" id="mail" name="mail" class="form-input"
                        placeholder="exemple@email.com" autocomplete="email" required>
                </div>
                <div class="form-group">
                    <label class="form-label" for="password">Mot de passe</label>
                    <input type="password" id="password" name="password" class="form-input"
                        placeholder="••••••••" autocomplete="current-password" required>
                </div>
                <button type="submit" class="btn btn-orange btn-full">Se connecter</button>
            </form>

            <p class="auth-link">Pas encore de compte ? <a href="/register">S'inscrire</a></p>

        </div>
    </div>

    <script src="/js/auth.js"></script>
    <script>
        const params = new URLSearchParams(window.location.search);
        if (params.get('registered') === '1') {
            const s = document.getElementById('success-msg');
            s.textContent = 'Compte créé avec succès ! Vous pouvez maintenant vous connecter.';
            s.classList.add('show');
        }
    </script>

</body>
</html>
